  "publicApiSurface": [
    "WMAB_Settings::get_menu_items()",
    "WMAB_Settings::get_white_label()",
    "WMAB_Settings::get_all_roles()",
    "woocommerce_account_menu_items filter (modified at priority 999)",
    "woocommerce_get_endpoint_url filter",
    "woocommerce_account_{slug}_endpoint action (for custom endpoints)"
