  "keyFeatures": [
    "Visual drag & drop menu builder with live preview",
    "Custom endpoints with HTML/shortcode content support",
    "External links with new-tab control",
    "Dashicons icon support with visual picker",
    "Role-based visibility per menu item",
    "Static badges and dynamic counters (orders, downloads)",
    "Menu separators for visual grouping",
    "White-label mode with complete rebranding",
    "Export/Import JSON configuration",
    "HPOS and Cart/Checkout Blocks compatible"
